generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  role                String               @default("AGENT")
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  emailVerified       DateTime?
  phone               String?
  calendarFeedId      String?              @unique
  accounts            Account[]
  Authenticator       Authenticator[]
  calendarIntegration CalendarIntegration?
  opportunities       Opportunity[]
  sessions            Session[]
  tasks               Task[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  provider     String   @default("google")
  accessToken  String?
  refreshToken String?
  expiresAt    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Contact {
  id                       String        @id @default(cuid())
  name                     String
  email                    String?
  phone                    String?
  stayStartDate            DateTime?
  stayEndDate              DateTime?
  militaryBase             String?
  lengthOfTrainingDays     Int?
  travelingWithKids        Boolean       @default(false)
  travelingWithDogs        Boolean       @default(false)
  travelingWithSpouse      Boolean       @default(false)
  needsEVCharging          Boolean       @default(false)
  hasNonAvailabilityLetter Boolean       @default(false)
  sourceKeyword            String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  status                   String?       @default("Lead")
  businessName             String?
  tags                     ContactTag[]
  documents                Document[]
  formTracking             FormTracking?
  messages                 Message[]
  notes                    Note[]
  opportunities            Opportunity[]
  tasks                    Task[]
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stages    PipelineStage[]
}

model PipelineStage {
  id            String        @id @default(cuid())
  pipelineId    String
  name          String
  order         Int
  opportunities Opportunity[]
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, name])
}

model Opportunity {
  id               String           @id @default(cuid())
  contactId        String
  pipelineStageId  String
  assigneeId       String?
  name             String?
  opportunityValue Float?
  estimatedProfit  Float?
  priority         String           @default("MEDIUM")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  monthlyRent      Float?
  perDiemRate      Float?
  leadSourceId     String?
  contact          Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipelineStage    PipelineStage    @relation(fields: [pipelineStageId], references: [id], onDelete: Cascade)
  assignee         User?            @relation(fields: [assigneeId], references: [id])
  leadSource       LeadSource?      @relation(fields: [leadSourceId], references: [id])
  tags             OpportunityTag[]
}

model FormTracking {
  id                    String   @id @default(cuid())
  contactId             String   @unique
  homeownerLeaseUrl     String?
  homeownerLeaseSigned  Boolean  @default(false)
  termsConditionsUrl    String?
  termsConditionsSigned Boolean  @default(false)
  paymentAuthUrl        String?
  paymentAuthSigned     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  contact               Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  contactId String
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  contactId String
  type      String
  direction String
  content   String
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  linkUrl   String?
  createdAt DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  priority    String    @default("MEDIUM")
  assigneeId  String?
  contactId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignee    User?     @relation(fields: [assigneeId], references: [id])
}

model LeadSource {
  id            String        @id @default(cuid())
  name          String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  opportunities Opportunity[]
}

model Tag {
  id              String           @id @default(cuid())
  name            String           @unique
  color           String           @default("#3b82f6")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contactTags     ContactTag[]
  opportunityTags OpportunityTag[]
}

model ContactTag {
  id        String  @id @default(cuid())
  contactId String
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
}

model OpportunityTag {
  id            String      @id @default(cuid())
  opportunityId String
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, tagId])
}

model Document {
  id        String   @id @default(cuid())
  contactId String
  name      String
  url       String
  status    String   @default("LINK")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model MilitaryBase {
  id        String              @id @default(cuid())
  name      String
  zipCode   String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  periods   BaseLodgingPeriod[]
}

model BaseLodgingPeriod {
  id        String       @id @default(cuid())
  baseId    String
  startDate String
  endDate   String
  rate      Float
  base      MilitaryBase @relation(fields: [baseId], references: [id], onDelete: Cascade)
}
